# RITS credentials — copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Full vLLM base URL including /v1
RITS_BASE_URL=https://inference.example.ibm.com/v1

# Bearer token sent as: Authorization: Bearer <token>
RITS_BEARER_TOKEN=your-bearer-token

# Sent as the RITS_API_KEY HTTP header
RITS_API_KEY=your-rits-api-key

# Model name as registered in your RITS deployment (optional — has a default)
RITS_MODEL=meta-llama/llama-3-1-70b-instruct
