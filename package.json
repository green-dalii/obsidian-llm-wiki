{
  "name": "karpathywiki",
  "version": "1.25.1",
  "packageManager": "pnpm@10.14.0",
  "description": "Karpathy's LLM Wiki implementation - multi-page knowledge generation with conversational query",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:dev": "node esbuild.config.mjs dev",
    "lint": "eslint src/ --max-warnings=0",
    "css-lint": "node scripts/css-lint.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "llm",
    "wiki",
    "karpathy",
    "knowledge-management",
    "multi-page",
    "conversational-query",
    "streaming"
  ],
  "author": "Greener-Dalii",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "16.18.126",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "esbuild": "0.28.1",
    "eslint": "10.2.1",
    "eslint-plugin-obsidianmd": "0.3.0",
    "jsdom": "^29.1.1",
    "obsidian": "1.12.3",
    "tslib": "2.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "fast-uri": "3.1.2",
      "brace-expansion": "5.0.6"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.98",
    "@ai-sdk/openai": "3.0.86",
    "@ai-sdk/openai-compatible": "2.0.62",
    "ai": "6.0.230",
    "zod": "^3.25.76"
  }
}